// Detection: Credential Stuffing
// Purpose: Find accounts with both failed and successful logins from same external IP
TitanShield_AuthenticationEvents
| where src_ip !contains "10.10"
| summarize failures = countif(result == "Failed Login"),
            successes = countif(result == "Successful Login") by username, src_ip
| where failures > 0 and successes > 0
| order by failures desc
